{
	"appId": "com.osteodio.app",
	"appName": "Osteodio",
	"webDir": "dist",
	"server": {
		"androidScheme": "https"
	},
	"ios": {
		"contentInset": "always"
	},
	"android": {
		"allowMixedContent": true
	},
	"plugins": {
		"SplashScreen": {
			"launchShowDuration": 3000,
			"backgroundColor": "#121212",
			"showSpinner": true,
			"spinnerColor": "#00D09C"
		}
	}
}
